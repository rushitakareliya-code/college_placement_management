<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Application Update – {{jobRole}} at {{company}}</title>
</head>
<body style="margin:0;padding:0;background:#f1f5f9;font-family:'Segoe UI',Arial,sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f1f5f9;padding:40px 0;">
    <tr>
      <td align="center">
        <table width="580" cellpadding="0" cellspacing="0"
          style="max-width:580px;width:100%;background:#ffffff;border-radius:16px;overflow:hidden;border:1px solid #e2e8f0;box-shadow:0 4px 24px rgba(0,0,0,0.06);">

          <!-- Header -->
          <tr>
            <td style="background:#0f172a;padding:28px 36px;">
              <table cellpadding="0" cellspacing="0">
                <tr>
                  <td>
                    <div style="width:36px;height:36px;background:#14b8a6;border-radius:8px;display:inline-block;text-align:center;line-height:36px;vertical-align:middle;margin-right:10px;">
                      <span style="color:#ffffff;font-size:18px;font-weight:bold;">P</span>
                    </div>
                  </td>
                  <td style="vertical-align:middle;">
                    <span style="color:#ffffff;font-size:22px;font-weight:700;letter-spacing:-0.5px;">PlacementHub</span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Red notice banner -->
          <tr>
            <td style="background:#fef2f2;padding:20px 36px;border-bottom:1px solid #fecaca;">
              <table cellpadding="0" cellspacing="0" width="100%">
                <tr>
                  <td width="44" style="vertical-align:middle;">
                    <div style="width:40px;height:40px;background:#dc2626;border-radius:50%;text-align:center;line-height:40px;">
                      <span style="color:#ffffff;font-size:22px;font-weight:bold;">✕</span>
                    </div>
                  </td>
                  <td style="vertical-align:middle;padding-left:14px;">
                    <p style="margin:0;color:#7f1d1d;font-size:16px;font-weight:700;">Unfortunately, your application was not selected.</p>
                    <p style="margin:4px 0 0;color:#991b1b;font-size:13px;">Please don't be discouraged — keep applying for other opportunities.</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding:36px;">

              <!-- Greeting -->
              <h2 style="color:#0f172a;margin:0 0 8px;font-size:20px;font-weight:700;">
                Hi {{studentName}}, an update on your application.
              </h2>
              <p style="color:#475569;margin:0 0 24px;font-size:14px;line-height:1.7;">
                Thank you for applying for <strong>{{jobRole}}</strong> at <strong>{{company}}</strong>.
                After careful consideration, we regret to inform you that your application has been
                <strong style="color:#dc2626;">not selected</strong> at this time.
                We appreciate your interest and encourage you to explore other available opportunities.
              </p>

              <!-- Job detail table -->
              <table width="100%" cellpadding="0" cellspacing="0"
                style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:0;margin-bottom:24px;">
                <tr>
                  <td style="padding:16px 20px;border-bottom:1px solid #e2e8f0;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td width="130" style="color:#94a3b8;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Position</td>
                        <td style="color:#0f172a;font-size:14px;font-weight:600;">{{jobRole}}</td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="padding:16px 20px;border-bottom:1px solid #e2e8f0;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td width="130" style="color:#94a3b8;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Company</td>
                        <td style="color:#0f172a;font-size:14px;font-weight:600;">{{company}}</td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="padding:16px 20px;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td width="130" style="color:#94a3b8;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Status</td>
                        <td>
                          <span style="background:#fef2f2;color:#dc2626;font-size:12px;font-weight:700;padding:3px 10px;border-radius:20px;border:1px solid #fecaca;">
                            ✕ Not Selected
                          </span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Encouragement box -->
              <div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:10px;padding:16px 20px;margin-bottom:28px;">
                <p style="margin:0 0 8px;color:#1e40af;font-size:13px;font-weight:700;">Don't give up — here's what you can do:</p>
                <ul style="margin:0;padding-left:18px;color:#3b82f6;font-size:13px;line-height:1.8;">
                  <li>Browse other open job listings on the portal</li>
                  <li>Update your profile and skills to improve your chances</li>
                  <li>Contact your TPO for guidance and career advice</li>
                </ul>
              </div>

              <p style="color:#475569;font-size:14px;line-height:1.7;margin:0 0 8px;">
                We wish you all the best,<br>
                <strong style="color:#0f172a;">The PlacementHub Team</strong>
              </p>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background:#f8fafc;border-top:1px solid #e2e8f0;padding:20px 36px;text-align:center;">
              <p style="margin:0;color:#94a3b8;font-size:12px;line-height:1.6;">
                © {{year}} PlacementHub · This is an automated email, please do not reply.<br>
                Status updated on: {{updatedAt}}
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>
