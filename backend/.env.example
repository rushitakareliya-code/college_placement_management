PORT=5000
MONGODB_URI=mongodb://localhost:27017/student_placement_db
JWT_SECRET=your_secret_key_change_in_production

# Redis (Bull email queue)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=

# ─── Mailtrap SMTP (Email Testing) ───────────────────────────────────────────
# Get credentials from: https://mailtrap.io → Email Testing → Inboxes → SMTP Settings → Nodemailer
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=<your_mailtrap_username>
SMTP_PASS=<your_mailtrap_password>
SMTP_FROM_NAME=Placement Portal
SMTP_FROM_EMAIL=noreply@placementhub.dev
